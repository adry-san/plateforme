<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tampon Circulaire</title>
  <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore-compat.js"></script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: sans-serif; background: #1a1a2e; color: white; min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 30px 20px; }
    h1 { font-size: 1.5rem; margin-bottom: 24px; color: #e2b96f; }
    input { width: 100%; padding: 12px; border-radius: 10px; border: none; font-size: 1rem; margin-bottom: 10px; background: #16213e; color: white; border: 1px solid #333; }
    button { width: 100%; padding: 14px; border-radius: 10px; border: none; font-size: 1rem; cursor: pointer; margin-bottom: 10px; font-weight: bold; transition: 0.2s; }
    #btn-add { background: #e2b96f; color: #1a1a2e; }
    #btn-generate { background: #4ecca3; color: #1a1a2e; }
    #btn-launch { background: #e94560; color: white; display: none; }
    #btn-reveal { background: #4ecca3; color: #1a1a2e; display: none; }
    #player-list { width: 100%; margin-bottom: 20px; }
    .player-tag { background: #16213e; border: 1px solid #444; border-radius: 8px; padding: 8px 14px; margin-bottom: 6px; display: flex; justify-content: space-between; }
    .remove-btn { background: none; border: none; color: #e94560; cursor: pointer; font-size: 1rem; width: auto; padding: 0; margin: 0; }
    #status { font-size: 1.2rem; text-align: center; margin: 20px 0; min-height: 60px; color: #4ecca3; }
    #reveal-box { background: #16213e; border: 2px solid #4ecca3; border-radius: 14px; padding: 30px; text-align: center; display: none; margin-top: 10px; }
    #reveal-box h2 { font-size: 2rem; color: #e2b96f; }
    #section-setup, #section-game { width: 100%; max-width: 420px; }
    #section-game { display: none; }
  </style>
</head>
<body>

<div id="section-setup">
  <h1>🎯 Tampon Circulaire</h1>
  <input type="text" id="input-name" placeholder="Nom du joueur..." />
  <button id="btn-add">+ Ajouter le joueur</button>
  <div id="player-list"></div>
  <button id="btn-generate">Générer le tampon</button>
</div>

<div id="section-game">
  <h1>🎯 Tampon Circulaire</h1>
  <div id="status"></div>
  <button id="btn-launch">▶ Lancer</button>
  <div id="reveal-box">
    <p style="margin-bottom:10px; color:#aaa;">Tu as pioché :</p>
    <h2 id="reveal-name"></h2>
  </div>
  <button id="btn-reveal" style="margin-top:14px">👁 Voir mon tirage</button>
</div>

<script>
  const firebaseConfig = {
    apiKey: "AIzaSyDlXhhS8Az04Z-55LHtJWqrVJt79LhSIAU",
    authDomain: "plateforme-77efd.firebaseapp.com",
    projectId: "plateforme-77efd",
    storageBucket: "plateforme-77efd.firebasestorage.app",
    messagingSenderId: "1061460763647",
    appId: "1:1061460763647:web:8b4ac092a21406cc49bdca"
  };

  firebase.initializeApp(firebaseConfig);
  const db = firebase.firestore();

  let players = [];
  let assignments = {};
  let order = [];
  let currentIndex = 0;
  let sessionId = null;

  document.getElementById('btn-add').addEventListener('click', () => {
    const input = document.getElementById('input-name');
    const name = input.value.trim();
    if (!name || players.includes(name)) return;
    players.push(name);
    input.value = '';
    renderPlayers();
  });

  document.getElementById('input-name').addEventListener('keydown', e => {
    if (e.key === 'Enter') document.getElementById('btn-add').click();
  });

  function renderPlayers() {
    const list = document.getElementById('player-list');
    list.innerHTML = '';
    players.forEach((p, i) => {
      const div = document.createElement('div');
      div.className = 'player-tag';
      div.innerHTML = `<span>${p}</span><button class="remove-btn" onclick="removePlayer(${i})">✕</button>`;
      list.appendChild(div);
    });
  }

  window.removePlayer = (i) => {
    players.splice(i, 1);
    renderPlayers();
  };

  document.getElementById('btn-generate').addEventListener('click', async () => {
    if (players.length < 2) return alert("Il faut au moins 2 joueurs !");
    assignments = generateCircle(players);
    order = [...players].sort(() => Math.random() - 0.5);
    currentIndex = 0;

    sessionId = Date.now().toString();
    await db.collection('sessions').doc(sessionId).set({
      assignments,
      order,
      currentIndex: 0,
      createdAt: new Date()
    });

    document.getElementById('section-setup').style.display = 'none';
    document.getElementById('section-game').style.display = 'block';
    showCurrentPlayer();
  });

  function generateCircle(names) {
    let shuffled = [...names].sort(() => Math.random() - 0.5);
    for (let i = 0; i < shuffled.length; i++) {
      if (shuffled[i] === names[i]) {
        const swap = (i + 1) % shuffled.length;
        [shuffled[i], shuffled[swap]] = [shuffled[swap], shuffled[i]];
      }
    }
    const result = {};
    names.forEach((name, i) => result[name] = shuffled[i]);
    return result;
  }

  function showCurrentPlayer() {
    const status = document.getElementById('status');
    const btnLaunch = document.getElementById('btn-launch');
    const revealBox = document.getElementById('reveal-box');

    revealBox.style.display = 'none';
    document.getElementById('btn-reveal').style.display = 'none';

    if (currentIndex >= order.length) {
      status.textContent = "✅ Tout le monde a vu son tirage !";
      btnLaunch.style.display = 'none';
      return;
    }

    const name = order[currentIndex];
    status.innerHTML = `Passe le téléphone à<br><strong style="font-size:1.8rem; color:#e2b96f">${name}</strong>`;
    btnLaunch.style.display = 'block';
    btnLaunch.textContent = `▶ ${name} est prêt(e)`;
  }

  document.getElementById('btn-launch').addEventListener('click', () => {
    document.getElementById('btn-launch').style.display = 'none';
    document.getElementById('btn-reveal').style.display = 'block';
    document.getElementById('status').innerHTML = `<strong style="color:#e2b96f">${order[currentIndex]}</strong>, clique pour voir ton tirage 👇`;
  });

  document.getElementById('btn-reveal').addEventListener('click', () => {
    const name = order[currentIndex];
    const target = assignments[name];
    document.getElementById('reveal-name').textContent = target;
    document.getElementById('reveal-box').style.display = 'block';
    document.getElementById('btn-reveal').style.display = 'none';

    setTimeout(() => {
      document.getElementById('reveal-box').style.display = 'none';
      currentIndex++;
      db.collection('sessions').doc(sessionId).update({ currentIndex });
      showCurrentPlayer();
    }, 3000);
  });
</script>
</body>
</html>
